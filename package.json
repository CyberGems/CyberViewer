{
  "name": "cyberviewer",
  "version": "1.6.2",
  "description": "CyberViewer — Visor de imágenes ultraligero por CyberGems",
  "main": "main.js",
  "author": "CyberGems <info@cybergems.com>",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never",
    "build:portable": "electron-builder --win portable --x64 --publish never",
    "test": "node --test test/**/*.test.js",
    "lint": "eslint main.js preload.js lib test"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^35.5.1",
    "electron-builder": "^24.0.0",
    "eslint": "^9.0.0"
  },
  "build": {
    "appId": "com.cybergems.cyberviewer",
    "productName": "CyberViewer",
    "copyright": "© 2026 CyberGems",
    "directories": {
      "output": "dist"
    },
    "files": [
      "CyberViewer.html",
      "main.js",
      "preload.js",
      "css/**",
      "js/**",
      "lib/**",
      "i18n/**",
      "assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "CyberGems",
      "repo": "CyberViewer"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "fileAssociations": [
        {
          "ext": [
            "jpg",
            "jpeg"
          ],
          "name": "JPEG Image",
          "role": "Viewer"
        },
        {
          "ext": [
            "png"
          ],
          "name": "PNG Image",
          "role": "Viewer"
        },
        {
          "ext": [
            "gif"
          ],
          "name": "GIF Image",
          "role": "Viewer"
        },
        {
          "ext": [
            "webp"
          ],
          "name": "WebP Image",
          "role": "Viewer"
        },
        {
          "ext": [
            "bmp"
          ],
          "name": "BMP Image",
          "role": "Viewer"
        },
        {
          "ext": [
            "tiff",
            "tif"
          ],
          "name": "TIFF Image",
          "role": "Viewer"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CyberViewer",
      "artifactName": "${productName} Setup ${version}.${ext}",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "${productName} Portable ${version}.${ext}"
    }
  }
}
