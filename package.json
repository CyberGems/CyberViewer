{
  "name": "cyberviewer",
  "version": "1.8.0",
  "description": "CyberViewer — Visor de imágenes ultraligero por CyberGems",
  "main": "main.js",
  "author": "CyberGems <info@cybergems.com>",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never",
    "build:portable": "electron-builder --win portable --x64 --publish never",
    "test": "node --test test/**/*.test.js",
    "lint": "eslint main.js preload.js lib test js",
    "i18n:sync": "node scripts/sync-i18n-ui.js"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^35.5.1",
    "electron-builder": "^24.0.0",
    "eslint": "^9.0.0"
  },
  "build": {
    "appId": "com.cybergems.cyberviewer",
    "productName": "CyberViewer",
    "copyright": "© 2026 CyberGems",
    "directories": {
      "output": "dist"
    },
    "files": [
      "CyberViewer.html",
      "main.js",
      "preload.js",
      "css/**",
      "js/**",
      "lib/**",
      "i18n/**",
      "assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "CyberGems",
      "repo": "CyberViewer"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "fileAssociations": [
        {
          "ext": ["jpg", "jpeg"],
          "name": "JPEG Image",
          "description": "JPEG Image",
          "progId": "CyberViewer.jpg",
          "role": "Viewer"
        },
        {
          "ext": ["png"],
          "name": "PNG Image",
          "description": "PNG Image",
          "progId": "CyberViewer.png",
          "role": "Viewer"
        },
        {
          "ext": ["gif"],
          "name": "GIF Image",
          "description": "GIF Image",
          "progId": "CyberViewer.gif",
          "role": "Viewer"
        },
        {
          "ext": ["webp"],
          "name": "WebP Image",
          "description": "WebP Image",
          "progId": "CyberViewer.webp",
          "role": "Viewer"
        },
        {
          "ext": ["bmp"],
          "name": "BMP Image",
          "description": "BMP Image",
          "progId": "CyberViewer.bmp",
          "role": "Viewer"
        },
        {
          "ext": ["tiff", "tif"],
          "name": "TIFF Image",
          "description": "TIFF Image",
          "progId": "CyberViewer.tiff",
          "role": "Viewer"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CyberViewer",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "runAfterFinish": true,
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
